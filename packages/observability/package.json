{
  "name": "@reaatech/agent-eval-harness-observability",
  "version": "0.1.0",
  "description": "OpenTelemetry observability (tracing, metrics, logging, dashboards) for agent-eval-harness",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opentelemetry/api": "~1.8.0",
    "@opentelemetry/core": "^2.7.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.51.0",
    "@opentelemetry/exporter-zipkin": "^2.7.1",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-metrics": "^1.24.0",
    "@opentelemetry/sdk-node": "^0.51.0",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.24.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/agent-eval-harness.git",
    "directory": "packages/observability"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "@types/node": "^22.10.0"
  },
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "homepage": "https://github.com/reaatech/agent-eval-harness/tree/main/packages/observability#readme",
  "bugs": {
    "url": "https://github.com/reaatech/agent-eval-harness/issues"
  }
}
