{
  "name": "@reaatech/agent-eval-harness-tool-use",
  "version": "0.1.0",
  "description": "Tool-use validation (selection, schema compliance, result verification) for agent-eval-harness",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@reaatech/agent-eval-harness-types": "workspace:*"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/agent-eval-harness.git",
    "directory": "packages/tool-use"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "@types/node": "^22.10.0"
  },
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "homepage": "https://github.com/reaatech/agent-eval-harness/tree/main/packages/tool-use#readme",
  "bugs": {
    "url": "https://github.com/reaatech/agent-eval-harness/issues"
  }
}
