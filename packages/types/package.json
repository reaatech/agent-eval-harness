{
  "name": "@reaatech/agent-eval-harness-types",
  "version": "0.1.0",
  "description": "Shared domain types and Zod schemas for agent-eval-harness",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "ajv": "^8.16.0",
    "json-schema": "^0.4.0",
    "zod": "^3.23.8"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/agent-eval-harness.git",
    "directory": "packages/types"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  },
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "homepage": "https://github.com/reaatech/agent-eval-harness/tree/main/packages/types#readme",
  "bugs": {
    "url": "https://github.com/reaatech/agent-eval-harness/issues"
  }
}
