{
  "name": "@reaatech/agent-eval-harness-cli",
  "version": "0.1.0",
  "description": "CLI interface for agent-eval-harness with eval, judge, compare, gate, golden, report, and serve commands",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agent-eval-harness": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@reaatech/agent-eval-harness-trajectory": "workspace:*",
    "@reaatech/agent-eval-harness-tool-use": "workspace:*",
    "@reaatech/agent-eval-harness-judge": "workspace:*",
    "@reaatech/agent-eval-harness-suite": "workspace:*",
    "@reaatech/agent-eval-harness-gate": "workspace:*",
    "@reaatech/agent-eval-harness-golden": "workspace:*",
    "@reaatech/agent-eval-harness-cost": "workspace:*",
    "@reaatech/agent-eval-harness-latency": "workspace:*",
    "@reaatech/agent-eval-harness-mcp-server": "workspace:*",
    "@reaatech/agent-eval-harness-observability": "workspace:*",
    "@reaatech/agent-eval-harness-types": "workspace:*",
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "commander": "^14.0.3",
    "yaml": "^2.8.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.5",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "@types/node": "^25.9.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/agent-eval-harness.git",
    "directory": "packages/cli"
  },
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "homepage": "https://github.com/reaatech/agent-eval-harness/tree/main/packages/cli#readme",
  "bugs": {
    "url": "https://github.com/reaatech/agent-eval-harness/issues"
  }
}
