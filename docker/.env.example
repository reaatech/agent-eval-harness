# LLM API Keys (all optional - only set the ones you need)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# OpenTelemetry Configuration
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=agent-eval-harness
OTEL_RESOURCE_ATTRIBUTES=service.version=0.1.0

# Log Level (debug, info, warn, error)
LOG_LEVEL=info

# Default Judge Model (claude-opus, gpt-4-turbo, gemini-pro)
DEFAULT_JUDGE_MODEL=claude-opus

# Cost Budget Limits (in USD)
JUDGE_BUDGET_LIMIT=50.00
MAX_COST_PER_JUDGMENT=0.10

# Rate Limits (requests per minute)
JUDGE_RATE_LIMIT=60

# Timeout (milliseconds)
JUDGE_TIMEOUT_MS=30000
