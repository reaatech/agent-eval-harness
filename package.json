{
  "name": "agent-eval-harness",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise-grade agent evaluation harness — monorepo of composable packages for trajectory evaluation, tool-use validation, cost tracking, latency budgets, golden trajectories, LLM-as-judge, CI regression gates, and MCP integration",
  "type": "module",
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.28.1",
    "@vitest/coverage-v8": "^3.2.4",
    "husky": "^9.0.11",
    "lint-staged": "^16.4.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/agent-eval-harness.git"
  },
  "bugs": {
    "url": "https://github.com/reaatech/agent-eval-harness/issues"
  },
  "homepage": "https://github.com/reaatech/agent-eval-harness#readme",
  "pnpm": {
    "overrides": {
      "uuid@<14.0.0": ">=14.0.0"
    }
  },
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "license": "MIT"
}
