{
  "name": "agent-eval-harness",
  "version": "0.1.0",
  "description": "End-to-end agent evaluation harness for full agent runs with trajectory evaluation, tool-use validation, cost tracking, latency budgets, golden trajectories, and LLM-as-judge",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agent-eval-harness": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./trajectory": {
      "types": "./dist/trajectory/index.d.ts",
      "import": "./dist/trajectory/index.js"
    },
    "./tool-use": {
      "types": "./dist/tool-use/index.d.ts",
      "import": "./dist/tool-use/index.js"
    },
    "./cost": {
      "types": "./dist/cost/index.d.ts",
      "import": "./dist/cost/index.js"
    },
    "./latency": {
      "types": "./dist/latency/index.d.ts",
      "import": "./dist/latency/index.js"
    },
    "./judge": {
      "types": "./dist/judge/index.d.ts",
      "import": "./dist/judge/index.js"
    },
    "./golden": {
      "types": "./dist/golden/index.d.ts",
      "import": "./dist/golden/index.js"
    },
    "./suite": {
      "types": "./dist/suite/index.d.ts",
      "import": "./dist/suite/index.js"
    },
    "./gate": {
      "types": "./dist/gate/index.d.ts",
      "import": "./dist/gate/index.js"
    },
    "./mcp-server": {
      "types": "./dist/mcp-server/index.d.ts",
      "import": "./dist/mcp-server/index.js"
    },
    "./observability": {
      "types": "./dist/observability/index.d.ts",
      "import": "./dist/observability/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "keywords": [
    "agent",
    "evaluation",
    "trajectory",
    "llm-judge",
    "ml-ops",
    "mcp"
  ],
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@google/generative-ai": "^0.21.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@opentelemetry/api": "^1.8.0",
    "@opentelemetry/auto-instrumentations-node": "^0.47.0",
    "@opentelemetry/core": "^2.7.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.51.0",
    "@opentelemetry/exporter-zipkin": "^1.30.1",
    "@opentelemetry/resources": "^1.24.0",
    "@opentelemetry/sdk-metrics": "^1.24.0",
    "@opentelemetry/sdk-node": "^0.51.0",
    "@opentelemetry/sdk-trace-node": "^1.24.0",
    "@opentelemetry/semantic-conventions": "^1.24.0",
    "ajv": "^8.16.0",
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "commander": "^12.1.0",
    "json-schema": "^0.4.0",
    "openai": "^4.52.0",
    "pino": "^9.2.0",
    "pino-pretty": "^13.1.3",
    "tiktoken": "^1.0.15",
    "yaml": "^2.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.5",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^8.57.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.3",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/agent-eval-harness.git"
  },
  "bugs": {
    "url": "https://github.com/reaatech/agent-eval-harness/issues"
  },
  "homepage": "https://github.com/reaatech/agent-eval-harness#readme"
}
